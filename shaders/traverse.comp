// Chunk dimension constants (must match Rust LOADED_CHUNKS_X/Y/Z)
const uint CHUNKS_X = 16;
const uint CHUNKS_Y = 4;
const uint CHUNKS_Z = 16;

// Check if a chunk at given texture-space chunk position is empty
bool isChunkEmpty(ivec3 chunkPos) {
    // Bounds check - out of bounds chunks are treated as empty
    if (chunkPos.x < 0 || chunkPos.x >= int(CHUNKS_X) ||
        chunkPos.y < 0 || chunkPos.y >= int(CHUNKS_Y) ||
        chunkPos.z < 0 || chunkPos.z >= int(CHUNKS_Z)) {
        return true;
    }

    // Calculate flat index: x + z * CHUNKS_X + y * CHUNKS_X * CHUNKS_Z
    uint idx = uint(chunkPos.x) + uint(chunkPos.z) * CHUNKS_X + uint(chunkPos.y) * CHUNKS_X * CHUNKS_Z;

    // Unpack bit from the appropriate uint32
    uint wordIdx = idx / 32u;
    uint bitIdx = idx % 32u;
    return (chunk_flags[wordIdx] & (1u << bitIdx)) != 0u;
}

// Calculate distance to exit current chunk (for chunk skipping)
// Returns t value to reach the exit face of the chunk
float getChunkExitT(vec3 pos, vec3 dir, vec3 invDir, ivec3 chunkPos) {
    vec3 chunkMin = vec3(chunkPos) * float(CHUNK_SIZE);
    vec3 chunkMax = chunkMin + float(CHUNK_SIZE);

    // Calculate t values to each face
    vec3 t1 = (chunkMin - pos) * invDir;
    vec3 t2 = (chunkMax - pos) * invDir;

    // Get exit t values (the far faces)
    vec3 tFar = max(t1, t2);

    // Return the closest exit (minimum of far faces)
    return min(min(tFar.x, tFar.y), tFar.z);
}

// Brick constants
const uint BRICK_SIZE = 8;        // 8³ voxels per brick
const uint BRICKS_PER_AXIS = 4;   // 32/8 = 4 bricks per chunk axis
const uint BRICKS_PER_CHUNK = 64; // 4×4×4 = 64 bricks per chunk

// Check if a brick at given voxel position is empty
// coord: texture-space voxel coordinate
bool isBrickEmpty(ivec3 coord) {
    // Calculate chunk position in texture space
    ivec3 chunkPos = coord / int(CHUNK_SIZE);

    // Bounds check
    if (chunkPos.x < 0 || chunkPos.x >= int(CHUNKS_X) ||
        chunkPos.y < 0 || chunkPos.y >= int(CHUNKS_Y) ||
        chunkPos.z < 0 || chunkPos.z >= int(CHUNKS_Z)) {
        return true;
    }

    // Calculate brick position within chunk (0-3 in each axis)
    ivec3 localVoxel = coord - chunkPos * int(CHUNK_SIZE);
    ivec3 brickPos = localVoxel / int(BRICK_SIZE);

    // Calculate brick index within chunk (0-63)
    uint brickIdx = uint(brickPos.x) + uint(brickPos.y) * BRICKS_PER_AXIS
                  + uint(brickPos.z) * BRICKS_PER_AXIS * BRICKS_PER_AXIS;

    // Calculate chunk index in flat buffer
    uint chunkIdx = uint(chunkPos.x) + uint(chunkPos.z) * CHUNKS_X
                  + uint(chunkPos.y) * CHUNKS_X * CHUNKS_Z;

    // Read brick mask (2 u32 per chunk)
    uint maskOffset = chunkIdx * 2u;
    uint wordIdx = brickIdx / 32u;
    uint bitIdx = brickIdx % 32u;
    uint mask = brick_masks[maskOffset + wordIdx];

    // Bit set = brick has solid blocks, so NOT set = empty
    return (mask & (1u << bitIdx)) == 0u;
}

// Get minimum distance to nearest solid brick (for sphere-tracing)
// coord: texture-space voxel coordinate
// Returns distance in brick units (multiply by BRICK_SIZE for voxels)
uint getBrickDistance(ivec3 coord) {
    // Calculate chunk position
    ivec3 chunkPos = coord / int(CHUNK_SIZE);

    // Bounds check - return 0 (treat as solid) for out-of-bounds
    if (chunkPos.x < 0 || chunkPos.x >= int(CHUNKS_X) ||
        chunkPos.y < 0 || chunkPos.y >= int(CHUNKS_Y) ||
        chunkPos.z < 0 || chunkPos.z >= int(CHUNKS_Z)) {
        return 0u;
    }

    // Calculate brick position within chunk
    ivec3 localVoxel = coord - chunkPos * int(CHUNK_SIZE);
    ivec3 brickPos = localVoxel / int(BRICK_SIZE);
    uint brickIdx = uint(brickPos.x) + uint(brickPos.y) * BRICKS_PER_AXIS
                  + uint(brickPos.z) * BRICKS_PER_AXIS * BRICKS_PER_AXIS;

    // Calculate chunk index
    uint chunkIdx = uint(chunkPos.x) + uint(chunkPos.z) * CHUNKS_X
                  + uint(chunkPos.y) * CHUNKS_X * CHUNKS_Z;

    // Read distance (16 u32 per chunk = 64 bytes, accessed as individual bytes)
    uint distOffset = chunkIdx * 16u + brickIdx / 4u;
    uint byteIdx = brickIdx % 4u;
    uint distWord = brick_distances[distOffset];

    // Extract byte from word
    return (distWord >> (byteIdx * 8u)) & 0xFFu;
}

// Calculate distance to exit current brick
float getBrickExitT(vec3 pos, vec3 dir, vec3 invDir, ivec3 brickWorldPos) {
    vec3 brickMin = vec3(brickWorldPos);
    vec3 brickMax = brickMin + float(BRICK_SIZE);

    vec3 t1 = (brickMin - pos) * invDir;
    vec3 t2 = (brickMax - pos) * invDir;

    vec3 tFar = max(t1, t2);
    return min(min(tFar.x, tFar.y), tFar.z);
}

// Get the world position of the brick containing this voxel
ivec3 getBrickWorldPos(ivec3 voxelCoord) {
    return (voxelCoord / int(BRICK_SIZE)) * int(BRICK_SIZE);
}

// Helper to get texture size as vec3 (the loaded chunk window)
vec3 textureSize3D() {
    return vec3(pc.texture_size_x, pc.texture_size_y, pc.texture_size_z);
}

uvec3 textureSizeU() {
    return uvec3(pc.texture_size_x, pc.texture_size_y, pc.texture_size_z);
}

// Get texture origin (world position that maps to texture 0,0,0)
ivec3 textureOrigin() {
    return ivec3(pc.texture_origin_x, pc.texture_origin_y, pc.texture_origin_z);
}

// Convert world coordinate to texture coordinate
ivec3 worldToTexture(ivec3 worldCoord) {
    return worldCoord - textureOrigin();
}

// Check if a texture coordinate is within the loaded texture bounds
bool isInTextureBounds(ivec3 texCoord) {
    return texCoord.x >= 0 && texCoord.x < int(pc.texture_size_x) &&
           texCoord.y >= 0 && texCoord.y < int(pc.texture_size_y) &&
           texCoord.z >= 0 && texCoord.z < int(pc.texture_size_z);
}

// Legacy compatibility - worldSize now means textureSize for ray marching bounds
vec3 worldSize() {
    return textureSize3D();
}

uvec3 worldSizeU() {
    return textureSizeU();
}

