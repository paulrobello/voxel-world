    float lod_ao_distance;         // Skip AO beyond this distance
    float lod_shadow_distance;     // Skip shadows beyond this distance
    float lod_point_light_distance; // Skip point lights beyond this distance
    // Falling block count
    uint falling_block_count;
} pc;

