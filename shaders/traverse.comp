    // Fog start distance
    float fog_start;
    // Whether fog affects sky (0 = false, 1 = true)
    uint fog_affects_sky;
    // Target block (block player is looking at, -1 = none)
    int target_block_x;
    int target_block_y;
    int target_block_z;
    // Maximum ray marching steps
    uint max_ray_steps;
    // Texture origin in world coordinates (world position that maps to texture 0,0,0)
