const vec3 SUN_COLOR = vec3(1.0, 0.95, 0.8);           // Warm white sun
const vec3 SUNSET_SUN_COLOR = vec3(1.0, 0.6, 0.3);     // Orange sunset sun
const float SUN_SIZE = 0.04;                            // Angular size of sun disk

// Moon settings
const vec3 MOON_COLOR = vec3(0.9, 0.9, 1.0);           // Cool white moon
const float MOON_SIZE = 0.03;                           // Slightly smaller than sun

// Cloud settings
const float CLOUD_HEIGHT = 80.0;       // Height of cloud layer
const float CLOUD_SCALE = 0.02;        // Scale of cloud noise
const float CLOUD_COVERAGE = 0.45;     // 0-1, higher = more clouds
const vec3 CLOUD_COLOR = vec3(1.0, 1.0, 1.0);   // White clouds
const vec2 CLOUD_WIND = vec2(0.8, 0.3);  // Wind direction and speed for cloud movement

// Fog settings (FOG_START/END used for particle fog, main fog uses density)
const float FOG_START = 40.0;     // Distance where particle fog begins
const float FOG_END = 120.0;      // Distance where particle fog is fully opaque

// Calculate sun direction based on time of day
// time: 0.0 = midnight, 0.25 = sunrise (east), 0.5 = noon (overhead), 0.75 = sunset (west)
vec3 getSunDirection(float time) {
    float angle = time * 2.0 * 3.14159265;  // Full rotation
    // Sun rises in east (+X), goes overhead (+Y), sets in west (-X)
    float y = -cos(angle);  // -1 at midnight, +1 at noon
    float xz = sin(angle);  // 0 at midnight/noon, +1 at sunrise, -1 at sunset
    return normalize(vec3(xz, y, 0.3));  // Slight Z offset for visual interest
}

// Calculate moon direction (opposite of sun)
vec3 getMoonDirection(float time) {
    return -getSunDirection(time);
}

// Get daylight factor (0 = full night, 1 = full day)
float getDaylightFactor(float time) {
    // Use sun's actual Y position for proper sync
    vec3 sunDir = getSunDirection(time);
    // Smooth transition: starts getting light when sun Y > -0.2, full day when Y > 0.3
    return smoothstep(-0.2, 0.3, sunDir.y);
}

// Get sunrise/sunset factor (peaks when sun is near horizon)
float getSunsetFactor(float time) {
    vec3 sunDir = getSunDirection(time);
    // Peak when sun is near horizon (Y close to 0)
    float horizonProximity = 1.0 - smoothstep(0.0, 0.4, abs(sunDir.y));
    // Only show sunset colors when sun is visible (not deep below horizon)
    float sunVisible = smoothstep(-0.3, 0.0, sunDir.y);
    return horizonProximity * sunVisible;
}

// Get current fog color based on time
vec3 getFogColor(float time) {
    float daylight = getDaylightFactor(time);
    float sunset = getSunsetFactor(time);

    vec3 dayFog = vec3(0.65, 0.78, 0.95);
    vec3 nightFog = vec3(0.05, 0.08, 0.15);
    vec3 sunsetFog = vec3(0.6, 0.4, 0.3);

    vec3 baseFog = mix(nightFog, dayFog, daylight);
    return mix(baseFog, sunsetFog, sunset * 0.5);
}

// Simple hash for noise
float hash(vec2 p) {
    return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
}

// 2D value noise
float noise2D(vec2 p) {
    vec2 i = floor(p);
    vec2 f = fract(p);
    f = f * f * (3.0 - 2.0 * f);  // Smoothstep

    float a = hash(i);
    float b = hash(i + vec2(1.0, 0.0));
    float c = hash(i + vec2(0.0, 1.0));
    float d = hash(i + vec2(1.0, 1.0));

    return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
}

// Fractal Brownian Motion for clouds
float fbm(vec2 p) {
    float value = 0.0;
    float amplitude = 0.5;
    float frequency = 1.0;

    for (int i = 0; i < 4; i++) {
        value += amplitude * noise2D(p * frequency);
        amplitude *= 0.5;
        frequency *= 2.0;
    }
    return value;
}

// Calculate cloud density at a point (animated with wind)
float getCloudDensity(vec3 rayOrigin, vec3 rayDir) {
    // Only render clouds above horizon
    if (rayDir.y <= 0.01) return 0.0;

    // Find intersection with cloud plane
    float t = (CLOUD_HEIGHT - rayOrigin.y) / rayDir.y;
    if (t < 0.0) return 0.0;

    vec3 cloudPos = rayOrigin + rayDir * t;

    // Convert to world coordinates so clouds don't shift when texture origin moves
    vec3 worldCloudPos = cloudPos + vec3(textureOrigin());

    // Animate clouds with wind - offset UV by time
    vec2 cloudUV = worldCloudPos.xz * CLOUD_SCALE + pc.animation_time * CLOUD_WIND * CLOUD_SCALE;

    // Sample cloud noise with multiple octaves for detail
    float density = fbm(cloudUV);

    // Add secondary layer moving at different speed for depth
    vec2 cloudUV2 = worldCloudPos.xz * CLOUD_SCALE * 0.5 + pc.animation_time * CLOUD_WIND * CLOUD_SCALE * 0.6;
    float density2 = fbm(cloudUV2) * 0.3;
    density = density + density2;

    // Apply coverage threshold
    density = smoothstep(CLOUD_COVERAGE, CLOUD_COVERAGE + 0.3, density);

    // Fade clouds at edges and with distance
    float distFade = 1.0 - smoothstep(200.0, 400.0, t);
    float horizonFade = smoothstep(0.01, 0.15, rayDir.y);

    return density * distFade * horizonFade;
}

// Generate stars based on direction
float getStars(vec3 dir) {
    // Use direction as seed for star positions
    vec2 starCoord = vec2(atan(dir.x, dir.z), asin(dir.y)) * 100.0;
    float star = hash(floor(starCoord));
    // Only show brightest "stars"
    star = step(0.995, star);
    // Twinkle effect
    star *= 0.5 + 0.5 * sin(hash(floor(starCoord) + 0.5) * 100.0);
    return star;
}

// Calculate sky color with sun, moon, stars and clouds
// Set underwaterView to true to disable sun/clouds (for underwater rendering)
vec3 getSkyColorEx(vec3 rayDir, bool underwaterView) {
    vec3 dir = normalize(rayDir);
    float y = dir.y;
    float time = pc.time_of_day;

    // Get time-based factors
    float daylight = getDaylightFactor(time);
    float sunset = getSunsetFactor(time);
    vec3 sunDir = getSunDirection(time);
    vec3 moonDir = getMoonDirection(time);

    // Interpolate sky colors based on time
    vec3 horizonColor = mix(NIGHT_SKY_HORIZON, DAY_SKY_HORIZON, daylight);
    vec3 zenithColor = mix(NIGHT_SKY_ZENITH, DAY_SKY_ZENITH, daylight);
    vec3 groundColor = mix(NIGHT_SKY_GROUND, DAY_SKY_GROUND, daylight);

    // Blend in sunset colors
    horizonColor = mix(horizonColor, SUNSET_HORIZON, sunset);
    zenithColor = mix(zenithColor, SUNSET_ZENITH, sunset * 0.5);
    groundColor = mix(groundColor, SUNSET_GROUND, sunset * 0.3);

    // Base sky gradient
    vec3 skyColor;
    if (y > 0.0) {
        float t = pow(y, 0.5);
        skyColor = mix(horizonColor, zenithColor, t);
    } else {
        float t = pow(-y, 0.7);
        skyColor = mix(horizonColor, groundColor, t);
    }

    // Skip celestial bodies and clouds when underwater
    if (underwaterView) {
        return skyColor;
    }

    // Add stars at night (only visible when dark)
    if (daylight < 0.5 && y > 0.0) {
        float starBrightness = (1.0 - daylight * 2.0) * getStars(dir);
        skyColor += vec3(starBrightness);
    }

    // Add moon at night
    float moonDot = dot(dir, moonDir);
    if (moonDot > 0.0 && daylight < 0.8) {
        float moonFactor = smoothstep(1.0 - MOON_SIZE, 1.0, moonDot);
        float moonBrightness = 1.0 - daylight;
        skyColor = mix(skyColor, MOON_COLOR, moonFactor * moonBrightness);

        // Subtle moon glow
        float moonGlow = pow(max(0.0, moonDot), 16.0) * 0.3 * moonBrightness;
        skyColor += MOON_COLOR * moonGlow;
    }

    // Add sun (only when above horizon-ish)
    float sunDot = dot(dir, sunDir);
    if (sunDot > 0.0 && sunDir.y > -0.2) {
        // Blend sun color from white to orange at sunset
        vec3 currentSunColor = mix(SUN_COLOR, SUNSET_SUN_COLOR, sunset);

        // Sun disk
        float sunFactor = smoothstep(1.0 - SUN_SIZE, 1.0, sunDot);
        skyColor = mix(skyColor, currentSunColor, sunFactor);

        // Sun glow (larger at sunset)
        float glowSize = 8.0 - sunset * 4.0;  // Larger glow at sunset
        float glowFactor = pow(max(0.0, sunDot), glowSize) * (0.5 + sunset * 0.3);
        skyColor += currentSunColor * glowFactor;
    }

    // Add clouds (only above horizon, dimmer at night)
    if (y > 0.0) {
        vec3 worldOrigin = pc.pixelToRay[3].xyz;
        float cloudDensity = getCloudDensity(worldOrigin, dir);

        // Cloud brightness based on time and sun direction
        float sunLight = max(0.2, dot(dir, sunDir) * 0.5 + 0.5);
        float cloudBrightness = mix(0.15, 1.0, daylight) * sunLight;

        // Tint clouds orange at sunset
        vec3 cloudColor = mix(CLOUD_COLOR * cloudBrightness, SUNSET_SUN_COLOR, sunset * 0.4);

        skyColor = mix(skyColor, cloudColor, cloudDensity * 0.9);
    }

    return skyColor;
}

// Default sky color (not underwater)
vec3 getSkyColor(vec3 rayDir) {
    return getSkyColorEx(rayDir, false);
}

// Calculate fog factor based on distance using exponential fog (0 = no fog, 1 = full fog)
float getFogFactor(float distance) {
    // No fog before fog_start distance
    if (distance < pc.fog_start) {
        return 0.0;
    }
    // Exponential fog starting from fog_start: 1 - exp(-density * (distance - fog_start))
    // pc.fog_density controls thickness (0 = no fog, 0.02 = light, 0.05 = medium, 0.1 = thick)
    float effectiveDistance = distance - pc.fog_start;
    return 1.0 - exp(-pc.fog_density * effectiveDistance);
}

// Get current sun direction for lighting calculations
vec3 getCurrentSunDir() {
    return getSunDirection(pc.time_of_day);
}

// Apply fog to a color
vec3 applyFog(vec3 color, float distance, vec3 rayDir) {
    float fogFactor = getFogFactor(distance);
    vec3 fogColor = getFogColor(pc.time_of_day);
    return mix(color, fogColor, fogFactor);
}

// Read block type at given texture coordinate (used by ray marching)
uint readBlockTypeAtTexCoord(ivec3 texCoord) {
    // Return air for coordinates outside loaded texture bounds
    if (!isInTextureBounds(texCoord)) {
        return BLOCK_AIR;
    }
    return imageLoad(blockImage, texCoord).r;
}

// Read block type at given world coordinate
// Translates world coords to texture coords using texture_origin
uint readBlockType(ivec3 worldCoord) {
    ivec3 texCoord = worldToTexture(worldCoord);
    return readBlockTypeAtTexCoord(texCoord);
}

// Check if block at world coordinate is solid (non-air)
bool isSolid(ivec3 worldCoord) {
    return readBlockType(worldCoord) != BLOCK_AIR;
}

// Check if block at texture coordinate is solid (non-air)
bool isSolidAtTexCoord(ivec3 texCoord) {
    return readBlockTypeAtTexCoord(texCoord) != BLOCK_AIR;
}

// Check if block at texture coordinate occludes light for AO purposes
// Excludes transparent/partial blocks: air, glass, water, leaves, and model blocks
bool isOccluderAtTexCoord(ivec3 texCoord) {
    uint blockType = readBlockTypeAtTexCoord(texCoord);
    return blockType != BLOCK_AIR && blockType != BLOCK_GLASS &&
           blockType != BLOCK_WATER && blockType != BLOCK_LEAVES &&
           blockType != BLOCK_MODEL;
}

// Check if texture coordinate is within bounds and solid
// Used by ray marching functions that work in texture space
bool isSolidSafe(ivec3 texCoord) {
    if (any(lessThan(texCoord, ivec3(0))) || any(greaterThanEqual(texCoord, ivec3(worldSizeU())))) {
        return false;
    }
    return isSolidAtTexCoord(texCoord);
}

// Check if texture coordinate is within bounds and occludes for AO
// Used by AO calculation - excludes transparent/partial blocks
bool isOccluderSafe(ivec3 texCoord) {
    if (any(lessThan(texCoord, ivec3(0))) || any(greaterThanEqual(texCoord, ivec3(worldSizeU())))) {
        return false;
    }
    return isOccluderAtTexCoord(texCoord);
}

const float FLT_MAX = 3.4028235e+38;

// Helper: test whether a ray passing through a model block actually hits its sub-voxel geometry
// rayOrigin should be inside the block being tested (or just beyond its entry face)
bool modelBlocksRay(vec3 rayOrigin, vec3 dir, ivec3 blockPos, uint model_id, uint rotation) {
    // Convert to block-local space and keep slightly inside bounds to avoid precision misses
    vec3 localOrigin = clamp(rayOrigin - vec3(blockPos),
                             vec3(SUB_VOXEL_EPS),
                             vec3(1.0 - SUB_VOXEL_EPS));

    ivec3 subHit;
    vec3 n;
    float t;
    return findSubVoxelHit(localOrigin, dir, model_id, rotation, subHit, n, t);
}

// Cast shadow ray from a point toward the sun
// Returns shadow factor: 0 = fully in shadow, 1 = fully lit
float castShadowRay(vec3 origin) {
    vec3 sunDir = getCurrentSunDir();

    // No shadows when sun is below horizon
    if (sunDir.y < 0.0) {
        return 0.3;  // Dim ambient at night
    }

    // Offset origin slightly to avoid self-intersection
    vec3 shadowOrigin = origin + sunDir * 0.01;
    vec3 rayPos = shadowOrigin; // tracked position along the shadow ray

    vec3 dir = sunDir;
    vec3 inv_dir = 1.0 / dir;
    inv_dir = clamp(inv_dir, vec3(-FLT_MAX), vec3(FLT_MAX));

    // Current voxel position
    ivec3 pos = ivec3(floor(shadowOrigin));
    ivec3 startPos = pos;  // used to skip self-voxel on first iteration

    // Step direction
    ivec3 step = ivec3(sign(dir));

    // Distance to next voxel boundary
    vec3 tMax = (vec3(pos) + 0.5 + 0.5 * vec3(step) - shadowOrigin) * inv_dir;
    vec3 tDelta = abs(inv_dir);

    // Max shadow ray distance
    const float MAX_SHADOW_DIST = 48.0;
    float dist = 0.0;

    // DDA shadow ray march (increased for larger world)
    for (int i = 0; i < 128; i++) {
        // Check bounds
        if (any(lessThan(pos, ivec3(0))) || any(greaterThanEqual(pos, ivec3(worldSizeU())))) {
            return 1.0;  // Exited world bounds = lit
        }

        // Check for solid block (but ignore transparent blocks like leaves, glass)
        // pos is in texture coordinates
        uint blockType = readBlockTypeAtTexCoord(pos);

        // Skip self-voxel to avoid self-shadow when origin is inside the hit block
        bool skipSelf = all(equal(pos, startPos));

        if (!skipSelf) {
            // Compute a point inside the current voxel for sub-voxel tests
            vec3 blockOrigin = rayPos + dir * 0.001;
            if (blockType == BLOCK_MODEL) {
                if (pc.enable_model_shadows == 0u) {
                    // Treat model as non-blocking when disabled
                } else {
                    // Consult model properties
                    uvec2 meta = readModelMetadata(pos);
                    uint model_id = meta.r;
                    uint rotation = meta.g & 3u;
                    const float MODEL_PARTIAL_SHADOW = 0.4;
                    // If metadata missing, still cast a soft shadow to avoid disappearing
                    if (model_id == 0u) {
                        return MODEL_PARTIAL_SHADOW;
                    }
                    ModelProperties props = model_properties[model_id];

                    // Check actual sub-voxel geometry to decide shadowing
                    if ((props.flags & MODEL_FLAG_LIGHT_BLOCK_FULL) != 0u ||
                        (props.flags & MODEL_FLAG_LIGHT_BLOCK_PARTIAL) != 0u) {
                        bool hitGeo = modelBlocksRay(blockOrigin, dir, pos, model_id, rotation);
                        if (hitGeo) {
                            if ((props.flags & MODEL_FLAG_LIGHT_BLOCK_PARTIAL) != 0u) {
                                return MODEL_PARTIAL_SHADOW;  // soft shadow through gaps
                            } else {
                                return 0.0;  // fully blocked
                            }
                        }
                        // Fallback: if geometry march misses, honor declared blocking to avoid missing shadows
                        if ((props.flags & MODEL_FLAG_LIGHT_BLOCK_FULL) != 0u) {
                            return 0.0;
                        }
                        if ((props.flags & MODEL_FLAG_LIGHT_BLOCK_PARTIAL) != 0u) {
                            return MODEL_PARTIAL_SHADOW;
                        }
                    }
                    // Non-blocking models: let light pass
                }
            } else if (blockType != BLOCK_AIR && blockType != BLOCK_LEAVES && blockType != BLOCK_GLASS && blockType != BLOCK_WATER) {
                return 0.0;  // Hit solid = in shadow
            }

            // Leaves cast partial shadow
            if (blockType == BLOCK_LEAVES) {
                return 0.5;  // Partial shadow through leaves
            }
        }
        else {
            // Advance ray to exit the current voxel before testing for shadow
            float advanceT = min(tMax.x, min(tMax.y, tMax.z)) + 0.001;
            rayPos += sunDir * advanceT;
            pos = ivec3(floor(rayPos));
            // Recompute tMax from the new position
            tMax = (vec3(pos) + 0.5 + 0.5 * vec3(step) - rayPos) * inv_dir;
            continue;
        }

        // Step to next voxel
        if (tMax.x < tMax.y && tMax.x < tMax.z) {
            dist = tMax.x;
            tMax.x += tDelta.x;
            pos.x += step.x;
        } else if (tMax.y < tMax.z) {
            dist = tMax.y;
            tMax.y += tDelta.y;
            pos.y += step.y;
        } else {
            dist = tMax.z;
            tMax.z += tDelta.z;
            pos.z += step.z;
        }

        // Move tracked ray position to the entry point of the next voxel
        rayPos += dir * dist;

        if (dist > MAX_SHADOW_DIST) {
            return 1.0;  // Too far = assume lit
        }
    }

    return 1.0;  // No hit = lit
}

// Check if a point has sky exposure (for ambient light)
// Returns 0.0 if underground/blocked, 1.0 if exposed to sky
float getSkyExposure(vec3 origin) {
    // Cast ray straight up
    vec3 dir = vec3(0.0, 1.0, 0.0);

    // Offset origin slightly to avoid self-intersection
    vec3 rayOrigin = origin + dir * 0.01;
    vec3 rayPos = rayOrigin;

    // Current voxel position
    ivec3 pos = ivec3(floor(rayOrigin));
    ivec3 startPos = pos;

    // Only step upward
    float tMax = (float(pos.y) + 1.0 - rayOrigin.y);
    float tDelta = 1.0;

    // March upward through voxels (increased for taller world: 128 blocks)
    for (int i = 0; i < 128; i++) {
        // Check if we've exited the world (reached sky)
        if (pos.y >= int(pc.texture_size_y)) {
            return 1.0;  // Reached sky = full exposure
        }

        // For infinite world, check if position is within loaded texture bounds
        // pos is already in texture coordinates
        if (!isInTextureBounds(pos)) {
            return 1.0;  // Out of loaded area = assume sky
        }

        // Point inside the current voxel (just past the entry face)
        vec3 blockOrigin = rayPos + dir * 0.001;

        // Check for solid block (pos is in texture coordinates)
        // Skip the starting voxel to avoid self-occlusion when inside a model
        uint blockType = readBlockTypeAtTexCoord(pos);
        bool skipSelf = all(equal(pos, startPos));

        if (!skipSelf) {
            const float MODEL_PARTIAL_EXPOSURE = 0.4;
            if (blockType == BLOCK_MODEL) {
                if (pc.enable_model_shadows == 0u) {
                    // Treat model as non-blocking for sky when disabled
                } else {
                    uvec2 meta = readModelMetadata(pos);
                    uint model_id = meta.r;
                    uint rotation = meta.g & 3u;
                    if (model_id == 0u) {
                        return MODEL_PARTIAL_EXPOSURE;  // Soft block sky if metadata missing
                    }
                    ModelProperties props = model_properties[model_id];

                    bool blocksRay = false;
                    if ((props.flags & MODEL_FLAG_LIGHT_BLOCK_FULL) != 0u ||
                        (props.flags & MODEL_FLAG_LIGHT_BLOCK_PARTIAL) != 0u) {
                        blocksRay = modelBlocksRay(blockOrigin, dir, pos, model_id, rotation);
                    }

                    if ((props.flags & MODEL_FLAG_LIGHT_BLOCK_FULL) != 0u ||
                        (props.flags & MODEL_FLAG_LIGHT_BLOCK_PARTIAL) != 0u) {
                        if (blocksRay) {
                            if ((props.flags & MODEL_FLAG_LIGHT_BLOCK_FULL) != 0u) {
                                return 0.0;  // Fully blocked
                            }
                            if ((props.flags & MODEL_FLAG_LIGHT_BLOCK_PARTIAL) != 0u) {
                                return MODEL_PARTIAL_EXPOSURE;  // Partial exposure through model geometry
                            }
                        } else {
                            // Fallback to declared blocking so we don't miss shadows/sky occlusion
                            if ((props.flags & MODEL_FLAG_LIGHT_BLOCK_FULL) != 0u) {
                                return 0.0;
                            }
                            if ((props.flags & MODEL_FLAG_LIGHT_BLOCK_PARTIAL) != 0u) {
                                return MODEL_PARTIAL_EXPOSURE;
                            }
                        }
                    }
                    // Non-blocking models let sky through
                }
            } else if (blockType != BLOCK_AIR && blockType != BLOCK_WATER &&
                       blockType != BLOCK_GLASS && blockType != BLOCK_LEAVES) {
                return 0.0;  // Blocked = underground
            }

            // Leaves provide partial sky exposure
            if (blockType == BLOCK_LEAVES) {
                return 0.4;  // Partial exposure under leaves
            }
        }
        else {
            // Advance one voxel up to get out of the starting cell
            rayPos += dir * (tMax + 0.001);
            pos = ivec3(floor(rayPos));
            tMax = 1.0;
            continue;
        }

        // Step up
        pos.y += 1;
        rayPos += dir * tDelta;
    }

    return 1.0;  // No hit after max iterations = assume sky
}

// Calculate ambient occlusion for a face
// Based on the classic voxel AO algorithm that checks the 4 corners
// Each corner samples 3 neighbors: 2 edge neighbors + 1 corner neighbor
// Returns AO value 0-1 (0 = fully occluded, 1 = no occlusion)
float calculateAO(ivec3 blockCoord, vec3 normal, vec2 uv) {
    // Determine the two tangent axes for this face
    ivec3 inormal = ivec3(normal);
    ivec3 tangent1, tangent2;

    if (abs(inormal.x) > 0) {
        tangent1 = ivec3(0, 1, 0);
        tangent2 = ivec3(0, 0, 1);
    } else if (abs(inormal.y) > 0) {
        tangent1 = ivec3(1, 0, 0);
        tangent2 = ivec3(0, 0, 1);
    } else {
        tangent1 = ivec3(1, 0, 0);
        tangent2 = ivec3(0, 1, 0);
    }

    // Sample position is offset by normal to check neighbors of the face
    ivec3 facePos = blockCoord + inormal;

    // Calculate AO for all 4 corners
    // Corner order: (0,0), (1,0), (0,1), (1,1) in UV space
    float ao[4];

    for (int i = 0; i < 4; i++) {
        // Corner offsets in tangent space
        int s1 = (i & 1) * 2 - 1;      // -1 or +1
        int s2 = ((i >> 1) & 1) * 2 - 1; // -1 or +1

        // Sample the 3 neighbors for this corner
        // Use isOccluderSafe to exclude transparent blocks (glass, water, model) from AO
        bool side1 = isOccluderSafe(facePos + tangent1 * s1);
        bool side2 = isOccluderSafe(facePos + tangent2 * s2);
        bool corner = isOccluderSafe(facePos + tangent1 * s1 + tangent2 * s2);

        // Classic AO formula: if both sides are solid, corner is fully occluded
        // Otherwise, count how many of the 3 neighbors are solid
        if (side1 && side2) {
            ao[i] = 0.0;
        } else {
            ao[i] = 1.0 - float(int(side1) + int(side2) + int(corner)) / 3.0;
        }
    }

    // Bilinear interpolation of corner AO values based on UV
    float u = uv.x;
    float v = uv.y;

    float ao_bottom = mix(ao[0], ao[1], u);
    float ao_top = mix(ao[2], ao[3], u);
    float ao_final = mix(ao_bottom, ao_top, v);

    // Remap to avoid too dark areas: 0.3 to 1.0 range
    return 0.3 + ao_final * 0.7;
}

// Check if a block position is at a chunk boundary edge
// Returns a value 0-1 indicating proximity to boundary (1 = on edge)
float chunkBoundaryFactor(vec3 hitPos, uint steppedAxis) {
    // Get local position within chunk
    vec3 chunkLocal = mod(hitPos, float(CHUNK_SIZE));

    // Check if we're near chunk edges (within 0.1 blocks of boundary)
    float edgeThreshold = 0.1;
    float factor = 0.0;

    // For the hit face, check the two axes perpendicular to the stepped axis
    for (int i = 0; i < 3; i++) {
        if (i == int(steppedAxis)) continue;

        float localCoord = chunkLocal[i];
        // Check if near 0 or CHUNK_SIZE boundary
        if (localCoord < edgeThreshold || localCoord > float(CHUNK_SIZE) - edgeThreshold) {
            factor = 1.0;
        }
    }

    return factor;
}

// Texture atlas constants
// Atlas is 1216x64 pixels with 19 textures (64x64 each) in a row
// Order: air(0), stone(1), dirt(2), grass(3), planks(4), leaves(5), sand(6), gravel(7), water(8), glass(9), log(10), torch(11), brick(12), snow(13), cobblestone(14), iron(15), bedrock(16), grass_side(17), log_top(18)
const float ATLAS_TILE_COUNT = 19.0;
const float ATLAS_TILE_SIZE = 1.0 / ATLAS_TILE_COUNT;

// Multi-face texture indices (for blocks with different side textures)
const uint TEX_GRASS_SIDE = 17;
const uint TEX_LOG_TOP = 18;

// Torch light settings
const vec3 TORCH_LIGHT_COLOR = vec3(1.0, 0.8, 0.5);  // Warm orange-yellow
const float TORCH_LIGHT_RADIUS = 10.0;               // Light falloff radius
const float TORCH_LIGHT_INTENSITY = 1.2;             // Base intensity

// Calculate point light contribution at a surface point
// Returns the total light color contribution from all point lights
vec3 calculatePointLights(vec3 worldPos, vec3 normal) {
    vec3 totalLight = vec3(0.0);

    for (uint i = 0; i < pc.light_count; i++) {
        PointLight light = lights[i];
        vec3 lightPos = light.pos_radius.xyz;
        float lightRadius = light.pos_radius.w;
        vec3 lightColor = light.color.rgb;
        float intensity = light.color.a;

        // Vector from surface to light
        vec3 toLight = lightPos - worldPos;
        float distance = length(toLight);

        // Skip if outside light radius
        if (distance > lightRadius) continue;

        // Normalize direction
        vec3 lightDir = toLight / distance;

        // Attenuation: smooth falloff based on distance
        float attenuation = 1.0 - smoothstep(0.0, lightRadius, distance);
        attenuation = attenuation * attenuation;  // Quadratic falloff

        // Diffuse lighting (N dot L)
        float diffuse = max(0.0, dot(normal, lightDir));

        // Add a bit of ambient from the light to illuminate even faces pointing away
        float ambient = 0.15;

        // Combine
        vec3 lightContrib = lightColor * intensity * attenuation * (diffuse + ambient);

        // Flickering effect for torches (subtle)
        float flicker = 0.95 + 0.05 * sin(pc.animation_time * 15.0 + float(i) * 7.3);
        flicker *= 0.97 + 0.03 * sin(pc.animation_time * 23.0 + float(i) * 11.1);
        lightContrib *= flicker;

        totalLight += lightContrib;
    }

    return totalLight;
}

// Sample a specific texture from the atlas
vec3 sampleTexture(uint textureIndex, vec2 uv) {
    float atlasU = (float(textureIndex) + fract(uv.x)) * ATLAS_TILE_SIZE;
    float atlasV = fract(uv.y);
    return texture(textureAtlas, vec2(atlasU, atlasV)).rgb;
}

// Get animated water UV distortion
vec2 getWaterUVAnimation(vec2 uv, vec3 texPos, float time) {
    // Convert texture position to world position for consistent patterns
    vec3 worldPos = texPos + vec3(textureOrigin());

    // Multiple layers of flowing distortion
    float t = time * 0.8;

    // Layer 1: Slow large-scale flow
    vec2 flow1 = vec2(
        noise2D(worldPos.xz * 0.3 + vec2(t * 0.15, t * 0.1)) - 0.5,
        noise2D(worldPos.xz * 0.3 + vec2(t * 0.1, -t * 0.12) + 50.0) - 0.5
    ) * 0.08;

    // Layer 2: Medium ripples
    vec2 flow2 = vec2(
        noise2D(worldPos.xz * 0.8 + vec2(-t * 0.25, t * 0.2)) - 0.5,
        noise2D(worldPos.xz * 0.8 + vec2(t * 0.18, t * 0.22) + 100.0) - 0.5
    ) * 0.04;

    // Layer 3: Small fast ripples
    vec2 flow3 = vec2(
        noise2D(worldPos.xz * 2.0 + vec2(t * 0.4, -t * 0.35)) - 0.5,
        noise2D(worldPos.xz * 2.0 + vec2(-t * 0.3, t * 0.4) + 150.0) - 0.5
    ) * 0.02;

    return uv + flow1 + flow2 + flow3;
}

// Get caustic light pattern for underwater surfaces
float getWaterCaustics(vec3 texPos, float time) {
    // Convert texture position to world position for consistent patterns
    vec3 worldPos = texPos + vec3(textureOrigin());

    float t = time * 1.2;
    vec2 pos = worldPos.xz;

    // Multiple overlapping caustic patterns
    float c1 = noise2D(pos * 1.5 + vec2(t * 0.3, t * 0.2));
    float c2 = noise2D(pos * 2.3 + vec2(-t * 0.25, t * 0.35) + 30.0);
    float c3 = noise2D(pos * 3.7 + vec2(t * 0.4, -t * 0.3) + 60.0);

    // Create bright caustic lines by thresholding
    float caustic = c1 * c2 + c2 * c3 + c1 * c3;
    caustic = smoothstep(0.3, 0.7, caustic);

    return caustic * 0.3;  // Subtle effect
}

// Get block color by sampling from texture atlas, with multi-face support
// normal: the face normal (used to determine which texture variant to use)
// local_hit: the hit position within the block (0-1 range)
// stepped_axis: which axis was stepped to reach this block (0=X, 1=Y, 2=Z)
// worldPos: world position of hit (for animated textures)
vec3 getBlockColor(uint blockType, vec3 local_hit, vec3 normal, uint stepped_axis, vec3 worldPos) {
    uint textureIndex = blockType;
    vec2 uv;

    // Calculate UV based on which face was hit
    if (stepped_axis == 0) {
        // X-axis face: use Y for vertical, Z for horizontal
        uv = vec2(local_hit.z, 1.0 - local_hit.y);
    } else if (stepped_axis == 1) {
        // Y-axis face (top/bottom): use X and Z
        uv = vec2(local_hit.x, local_hit.z);
    } else {
        // Z-axis face: use X for horizontal, Y for vertical
        uv = vec2(local_hit.x, 1.0 - local_hit.y);
    }

    // Multi-face texture selection based on which face is hit
    if (blockType == BLOCK_GRASS) {
        if (normal.y > 0.5) {
            // Top face: grass texture
            textureIndex = BLOCK_GRASS;
        } else if (normal.y < -0.5) {
            // Bottom face: dirt
            textureIndex = BLOCK_DIRT;
        } else {
            // Side faces: use dirt texture with grass tint at top edge
            vec3 dirtColor = sampleTexture(BLOCK_DIRT, uv);
            vec3 grassColor = sampleTexture(BLOCK_GRASS, uv);

            // Blend grass color at top edge (where local_hit.y is close to 1)
            float grassEdge = smoothstep(0.75, 0.95, local_hit.y);
            return mix(dirtColor, grassColor, grassEdge);
        }
    } else if (blockType == BLOCK_LOG) {
        if (abs(normal.y) > 0.5) {
            // Top/bottom faces: tree rings
            textureIndex = TEX_LOG_TOP;
        } else {
            // Side faces: bark
            textureIndex = BLOCK_LOG;
        }
    } else if (blockType == BLOCK_WATER) {
        // Animated water texture with flowing UV distortion
        vec2 animatedUV = getWaterUVAnimation(uv, worldPos, pc.animation_time);
        vec3 waterColor = sampleTexture(BLOCK_WATER, animatedUV);

        // Add caustic highlights on top face
        if (normal.y > 0.5) {
            float caustics = getWaterCaustics(worldPos, pc.animation_time);
            waterColor += vec3(caustics);
        }

        return waterColor;
    }

    return sampleTexture(textureIndex, uv);
}

// Water rendering settings
const vec3 WATER_COLOR = vec3(0.2, 0.5, 0.8);  // Blue tint
const vec3 WATER_DEEP_COLOR = vec3(0.05, 0.15, 0.3);  // Darker deep water
const float WATER_CLARITY = 8.0;  // How far you can see through water
const float WATER_REFLECTIVITY = 0.3;  // Base surface reflectivity
const float WATER_FRESNEL_POWER = 3.0;  // Fresnel falloff

// Water wave animation settings
const float WAVE_SPEED = 1.2;        // How fast waves move
const float WAVE_SCALE = 0.8;        // Scale of wave pattern
const float WAVE_AMPLITUDE = 0.15;   // Height of wave displacement
const float WAVE_NORMAL_STRENGTH = 0.4;  // How much waves affect surface normal

// Calculate animated water wave normal at a position
// Returns a perturbed normal based on multi-octave animated noise
vec3 getWaterWaveNormal(vec3 texPos, float time) {
    // Convert texture position to world position for consistent patterns
    vec3 worldPos = texPos + vec3(textureOrigin());
    vec2 pos = worldPos.xz;

    // Multiple wave layers at different scales and speeds
    float t = time * WAVE_SPEED;

    // Layer 1: Large slow waves
    vec2 wave1Pos = pos * WAVE_SCALE * 0.5 + vec2(t * 0.3, t * 0.2);
    float h1 = noise2D(wave1Pos) * 2.0 - 1.0;

    // Layer 2: Medium waves
    vec2 wave2Pos = pos * WAVE_SCALE * 1.0 + vec2(-t * 0.4, t * 0.35);
    float h2 = noise2D(wave2Pos) * 2.0 - 1.0;

    // Layer 3: Small ripples
    vec2 wave3Pos = pos * WAVE_SCALE * 2.5 + vec2(t * 0.5, -t * 0.45);
    float h3 = noise2D(wave3Pos) * 2.0 - 1.0;

    // Combine waves with decreasing amplitude for higher frequencies
    float totalHeight = h1 * 0.5 + h2 * 0.3 + h3 * 0.2;

    // Calculate gradient for normal (using finite differences)
    float delta = 0.1;
    vec2 offsetX = vec2(delta, 0.0);
    vec2 offsetZ = vec2(0.0, delta);

    // Sample heights at offset positions
    float hpx = noise2D((pos + offsetX) * WAVE_SCALE * 0.5 + vec2(t * 0.3, t * 0.2)) * 0.5
              + noise2D((pos + offsetX) * WAVE_SCALE * 1.0 + vec2(-t * 0.4, t * 0.35)) * 0.3
              + noise2D((pos + offsetX) * WAVE_SCALE * 2.5 + vec2(t * 0.5, -t * 0.45)) * 0.2;

    float hpz = noise2D((pos + offsetZ) * WAVE_SCALE * 0.5 + vec2(t * 0.3, t * 0.2)) * 0.5
              + noise2D((pos + offsetZ) * WAVE_SCALE * 1.0 + vec2(-t * 0.4, t * 0.35)) * 0.3
              + noise2D((pos + offsetZ) * WAVE_SCALE * 2.5 + vec2(t * 0.5, -t * 0.45)) * 0.2;

    // Gradient
    float dx = (hpx - totalHeight) / delta;
    float dz = (hpz - totalHeight) / delta;

    // Create normal from gradient (scaled by amplitude and strength)
    vec3 waveNormal = normalize(vec3(
        -dx * WAVE_AMPLITUDE * WAVE_NORMAL_STRENGTH,
        1.0,
        -dz * WAVE_AMPLITUDE * WAVE_NORMAL_STRENGTH
    ));

    return waveNormal;
}

// Generate procedural crack pattern for block breaking
// uv: texture coordinates (0-1), progress: break progress (0-1)
// Returns crack intensity (0 = no crack, 1 = full crack/dark)
float getCrackPattern(vec2 uv, float progress) {
    if (progress <= 0.0) return 0.0;

    // Scale UV for crack pattern density
    vec2 crackUV = uv * 4.0;

    // Use multiple noise octaves for crack-like pattern
    float n1 = noise2D(crackUV * 2.0);
    float n2 = noise2D(crackUV * 4.0 + 1.23);
    float n3 = noise2D(crackUV * 8.0 + 4.56);

    // Combine noises - higher frequencies get emphasized as progress increases
    float noise = n1 * 0.5 + n2 * 0.3 + n3 * 0.2;

    // Create crack lines by taking absolute value and inverting
    // This creates dark lines where noise crosses zero
    float crackLines = 1.0 - abs(noise * 2.0 - 1.0);
    crackLines = pow(crackLines, 2.0);  // Sharpen the lines

    // Progressive reveal: more cracks appear as progress increases
    // At low progress, only show strongest cracks
    // At high progress, show all cracks
    float threshold = 1.0 - progress;
    float crack = smoothstep(threshold, threshold + 0.3, crackLines);

    // Add some chunky breakage at high progress
    if (progress > 0.7) {
        float chunks = noise2D(crackUV * 1.5 + 7.89);
        chunks = step(0.6 + (1.0 - progress) * 0.5, chunks);
        crack = max(crack, chunks * (progress - 0.7) / 0.3);
    }

    return crack * progress;  // Scale overall darkness by progress
}

// Check if a block position matches the breaking block
bool isBreakingBlock(ivec3 blockPos) {
    return pc.break_block_x >= 0 &&
           blockPos.x == pc.break_block_x &&
           blockPos.y == pc.break_block_y &&
           blockPos.z == pc.break_block_z;
}

// Ray-AABB (axis-aligned bounding box) intersection test for cube particles
// Returns t (distance along ray) or -1 if no hit
// Also outputs the face normal of the hit face
float rayAABBIntersect(vec3 rayOrigin, vec3 rayDir, vec3 boxCenter, float boxHalfSize, out vec3 hitNormal) {
    vec3 boxMin = boxCenter - vec3(boxHalfSize);
    vec3 boxMax = boxCenter + vec3(boxHalfSize);

    vec3 invDir = 1.0 / rayDir;

    vec3 t1 = (boxMin - rayOrigin) * invDir;
    vec3 t2 = (boxMax - rayOrigin) * invDir;

    vec3 tmin = min(t1, t2);
    vec3 tmax = max(t1, t2);

    float tNear = max(max(tmin.x, tmin.y), tmin.z);
    float tFar = min(min(tmax.x, tmax.y), tmax.z);

    // No hit if box is behind ray or ray misses box
    if (tNear > tFar || tFar < 0.0) {
        return -1.0;
    }

    // Use tNear if in front of ray, otherwise tFar (we're inside the box)
    float t = tNear > 0.0 ? tNear : tFar;
    if (t < 0.0) {
        return -1.0;
    }

    // Calculate which face was hit based on which axis had the largest tmin
    hitNormal = vec3(0.0);
    if (tmin.x >= tmin.y && tmin.x >= tmin.z) {
        hitNormal.x = -sign(rayDir.x);
    } else if (tmin.y >= tmin.z) {
        hitNormal.y = -sign(rayDir.y);
    } else {
        hitNormal.z = -sign(rayDir.z);
    }

    return t;
}

// Render particles and composite over the scene
// Returns true if a particle was hit, modifies color and hitDistance
bool renderParticles(vec3 origin, vec3 dir, inout vec3 color, inout float hitDistance) {
    bool anyHit = false;
    float closestT = hitDistance;
    vec3 closestColor = color;
    float closestAlpha = 0.0;

    for (uint i = 0; i < pc.particle_count; i++) {
        Particle p = particles[i];
        vec3 particlePos = p.pos_size.xyz;
        float particleSize = p.pos_size.w;  // This is half the cube size
        vec3 particleColor = p.color_alpha.rgb;
        float particleAlpha = p.color_alpha.a;

        // Ray-AABB intersection for cube particles
        vec3 faceNormal;
        float t = rayAABBIntersect(origin, dir, particlePos, particleSize, faceNormal);
        if (t > 0.0 && t < closestT) {
            // Calculate lighting using the cube face normal
            vec3 sunDir = getCurrentSunDir();
            float daylight = getDaylightFactor(pc.time_of_day);

            // Directional lighting from sun
            float sunLight = max(0.0, dot(faceNormal, sunDir));
            float ambient = mix(0.2, 0.4, daylight);
            float direct = mix(0.1, 0.6, daylight) * sunLight;
            float lighting = ambient + direct;

            // Update closest hit
            closestT = t;
            closestColor = particleColor * lighting;
            closestAlpha = particleAlpha;
            anyHit = true;
        }
    }

    if (anyHit) {
        // Blend particle color with background
        color = mix(color, closestColor, closestAlpha);
        hitDistance = min(hitDistance, closestT);
    }

    return anyHit;
}

// Render falling blocks and composite over the scene
// Returns true if a falling block was hit, modifies color and hitDistance
bool renderFallingBlocks(vec3 origin, vec3 dir, inout vec3 color, inout float hitDistance) {
    bool anyHit = false;
    float closestT = hitDistance;
    vec3 closestColor = color;

    for (uint i = 0; i < pc.falling_block_count; i++) {
        FallingBlock fb = falling_blocks[i];
        vec3 blockCenter = fb.pos_type.xyz;
        uint blockType = uint(fb.pos_type.w);

        // Ray-AABB intersection for 1.0 sized cube (half-size = 0.5)
        vec3 faceNormal;
        float t = rayAABBIntersect(origin, dir, blockCenter, 0.5, faceNormal);
        if (t > 0.0 && t < closestT) {
            // Calculate hit position
            vec3 hitPos = origin + dir * t;
            vec3 localHit = hitPos - (blockCenter - vec3(0.5));  // Convert to 0-1 range

            // Calculate UV based on which face was hit
            vec2 uv;
            uint stepped_axis;
            if (abs(faceNormal.x) > 0.5) {
                // X-axis face
                uv = vec2(localHit.z, 1.0 - localHit.y);
                stepped_axis = 0;
            } else if (abs(faceNormal.y) > 0.5) {
                // Y-axis face (top/bottom)
                uv = vec2(localHit.x, localHit.z);
                stepped_axis = 1;
            } else {
                // Z-axis face
                uv = vec2(localHit.x, 1.0 - localHit.y);
                stepped_axis = 2;
            }

            // Sample texture from atlas
            vec3 texColor = sampleTexture(blockType, uv);

            // Calculate lighting (match static block lighting)
            vec3 sunDir = getCurrentSunDir();
            float daylight = getDaylightFactor(pc.time_of_day);
            float sunLight = max(0.0, dot(faceNormal, sunDir));

            // Use same ambient calculation as static blocks
            // Falling blocks are in open air so skyExposure = 1.0
            float baseAmbient = mix(pc.ambient_light, pc.ambient_light + 0.25, daylight);
            float ambient = baseAmbient;

            // Cast shadow ray for falling block (optional, adds realism)
            float shadow = castShadowRay(hitPos + faceNormal * 0.01);

            // Direct light matching static blocks
            float direct = mix(0.2, 0.65, daylight) * sunLight * shadow;
            float lighting = ambient + direct;

            // Update closest hit
            closestT = t;
            closestColor = texColor * lighting;
            anyHit = true;
        }
    }

    if (anyHit) {
        color = closestColor;  // Falling blocks are opaque
        hitDistance = closestT;
    }

    return anyHit;
}

// Check if preview block is active
bool hasPreviewBlock() {
    return pc.preview_block_x >= 0;
}

// Check if target block is active
bool hasTargetBlock() {
    return pc.target_block_x >= 0;
}

// Check if a texture coordinate is the target block
bool isTargetBlock(ivec3 texCoord) {
    return hasTargetBlock() &&
           texCoord.x == pc.target_block_x &&
           texCoord.y == pc.target_block_y &&
           texCoord.z == pc.target_block_z;
}

// Apply target highlight to a color (cyan glow)
vec3 applyTargetHighlight(vec3 color) {
    // Brighten the color and add a cyan tint
    vec3 brightened = color * 1.45 + vec3(0.15);  // Brighten
    vec3 cyanTint = vec3(0.55, 1.0, 1.0);  // Cyan shift (reduce red)
    return min(brightened * cyanTint, vec3(1.0));  // Clamp to avoid overflow
}

// Ray-AABB intersection for unit cube at integer position
// Returns t (distance) or -1 if no hit, also outputs hit normal and local hit position
float rayBlockIntersect(vec3 rayOrigin, vec3 rayDir, ivec3 blockPos, out vec3 hitNormal, out vec3 localHit) {
    vec3 boxMin = vec3(blockPos);
    vec3 boxMax = vec3(blockPos) + vec3(1.0);

    // Guard against zero components to avoid INF/NaN when the ray is axis-aligned
    vec3 safeDir = rayDir;
    const float DIR_EPS = 1e-4;
    safeDir.x = (abs(safeDir.x) < DIR_EPS) ? (safeDir.x >= 0.0 ? DIR_EPS : -DIR_EPS) : safeDir.x;
    safeDir.y = (abs(safeDir.y) < DIR_EPS) ? (safeDir.y >= 0.0 ? DIR_EPS : -DIR_EPS) : safeDir.y;
    safeDir.z = (abs(safeDir.z) < DIR_EPS) ? (safeDir.z >= 0.0 ? DIR_EPS : -DIR_EPS) : safeDir.z;
    vec3 invDir = 1.0 / safeDir;

    vec3 t1 = (boxMin - rayOrigin) * invDir;
    vec3 t2 = (boxMax - rayOrigin) * invDir;

    vec3 tmin = min(t1, t2);
    vec3 tmax = max(t1, t2);

    float tNear = max(max(tmin.x, tmin.y), tmin.z);
    float tFar = min(min(tmax.x, tmax.y), tmax.z);

    if (tNear > tFar || tFar < 0.0) {
        return -1.0;
    }

    float t = tNear > 0.0 ? tNear : tFar;
    if (t < 0.0) {
        return -1.0;
    }

    // Calculate hit normal
    hitNormal = vec3(0.0);
    if (tmin.x >= tmin.y && tmin.x >= tmin.z) {
        hitNormal.x = -sign(rayDir.x);
    } else if (tmin.y >= tmin.z) {
        hitNormal.y = -sign(rayDir.y);
    } else {
        hitNormal.z = -sign(rayDir.z);
    }

    // Calculate local hit position (0-1 within block)
    vec3 hitPoint = rayOrigin + rayDir * t;
    localHit = hitPoint - vec3(blockPos);

    // Clamp to [0,1] to avoid boundary precision issues
    localHit = clamp(localHit, vec3(0.0), vec3(1.0));

    return t;
}

// Calculate wireframe factor for block preview edges
float getWireframeFactor(vec3 localHit, vec3 normal) {
    // Determine which two axes to check based on face normal
    vec2 edgeCoords;
    if (abs(normal.x) > 0.5) {
        edgeCoords = localHit.yz;
    } else if (abs(normal.y) > 0.5) {
        edgeCoords = localHit.xz;
    } else {
        edgeCoords = localHit.xy;
    }

    // Distance from edges (0-0.5 range, 0 = on edge)
    float edgeWidth = 0.08;
    float dx = min(edgeCoords.x, 1.0 - edgeCoords.x);
    float dy = min(edgeCoords.y, 1.0 - edgeCoords.y);
    float edgeDist = min(dx, dy);

    // Sharp wireframe line
    return 1.0 - smoothstep(0.0, edgeWidth, edgeDist);
}

// Render block placement preview
// Returns true if preview was rendered, blends into color
bool renderPreviewBlock(vec3 origin, vec3 dir, inout vec3 color, float sceneHitDistance) {
    if (!hasPreviewBlock()) {
        return false;
    }

    ivec3 previewPos = ivec3(pc.preview_block_x, pc.preview_block_y, pc.preview_block_z);

    vec3 hitNormal;
    vec3 localHit;
    float t = rayBlockIntersect(origin, dir, previewPos, hitNormal, localHit);

    // Only render if we hit the preview and it's in front of scene geometry
    // Convert t to world units (sceneHitDistance is already in world units)
    float tWorld = t * length(dir);
    if (t < 0.0 || tWorld > sceneHitDistance) {
        return false;
    }

    // Get the block color for the preview block type
    vec3 hitPoint = origin + dir * t;
    uint steppedAxis = 0;
    if (abs(hitNormal.y) > 0.5) steppedAxis = 1;
    else if (abs(hitNormal.z) > 0.5) steppedAxis = 2;

    vec3 previewColor = getBlockColor(pc.preview_block_type, localHit, hitNormal, steppedAxis, hitPoint);

    // Apply basic lighting
    vec3 sunDir = getCurrentSunDir();
    float daylight = getDaylightFactor(pc.time_of_day);
    float sunLight = max(0.0, dot(hitNormal, sunDir));
    float ambient = mix(0.3, 0.5, daylight);
    float direct = mix(0.2, 0.5, daylight) * sunLight;
    previewColor *= (ambient + direct);

    // Calculate wireframe
    float wireframe = getWireframeFactor(localHit, hitNormal);

    // Preview is mostly opaque with bright wireframe edges
    float baseAlpha = 0.75;
    float wireAlpha = 0.95;

    // Wireframe color (bright white/cyan)
    vec3 wireColor = vec3(0.8, 1.0, 1.0);

    // Blend: wireframe on edges, translucent block fill
    vec3 finalPreview = mix(previewColor, wireColor, wireframe);
    float finalAlpha = mix(baseAlpha, wireAlpha, wireframe);

    // Pulse effect for visibility
    float pulse = 0.9 + 0.1 * sin(pc.animation_time * 4.0);
    finalAlpha *= pulse;

    color = mix(color, finalPreview, finalAlpha);
    return true;
}

// Find which sub-voxel is hit in a model block and output the hit sub-voxel position
bool findSubVoxelHit(
    vec3 origin,  // Ray origin in block-local 0-1 space
    vec3 dir,
    uint model_id,
    uint rotation,
    out ivec3 hitSubVoxel,
    out vec3 hitNormal,
    out float hitT
) {
    // Scale to sub-voxel coordinates (0-8)
    vec3 pos = origin * float(SUB_VOXEL_SIZE);
    vec3 invDir = 1.0 / dir;

    // Calculate entry t
    vec3 tMin = (vec3(0.0) - pos) * invDir;
    vec3 tMax = (vec3(float(SUB_VOXEL_SIZE)) - pos) * invDir;

    vec3 t1 = min(tMin, tMax);
    vec3 t2 = max(tMin, tMax);

    float tNear = max(max(t1.x, t1.y), t1.z);
    float tFar = min(min(t2.x, t2.y), t2.z);

    if (tNear > tFar || tFar < 0.0) {
        return false;
    }

    float startT = max(tNear, 0.0);
    vec3 startPos = pos + dir * startT;

    ivec3 voxel = ivec3(floor(startPos));
    voxel = clamp(voxel, ivec3(0), ivec3(int(SUB_VOXEL_SIZE) - 1));

    ivec3 step = ivec3(sign(dir));
    vec3 tDelta = abs(invDir);

    vec3 tMaxAxis;
    tMaxAxis.x = (dir.x > 0.0) ? (float(voxel.x + 1) - startPos.x) * invDir.x
                                : (startPos.x - float(voxel.x)) * (-invDir.x);
    tMaxAxis.y = (dir.y > 0.0) ? (float(voxel.y + 1) - startPos.y) * invDir.y
                                : (startPos.y - float(voxel.y)) * (-invDir.y);
    tMaxAxis.z = (dir.z > 0.0) ? (float(voxel.z + 1) - startPos.z) * invDir.z
                                : (startPos.z - float(voxel.z)) * (-invDir.z);

    uint stepped_axis = 0u;

    for (int i = 0; i < 24; i++) {
        if (any(lessThan(voxel, ivec3(0))) || any(greaterThanEqual(voxel, ivec3(int(SUB_VOXEL_SIZE))))) {
            break;
        }

        ivec3 rotatedPos = rotateModelPos(voxel, rotation);
        rotatedPos = clamp(rotatedPos, ivec3(0), ivec3(int(SUB_VOXEL_SIZE) - 1));
        uint palette_idx = sampleModelVoxel(model_id, rotatedPos);

        if (palette_idx != 0u) {
            hitSubVoxel = voxel;
            hitNormal = vec3(0.0);
            hitNormal[stepped_axis] = -float(step[stepped_axis]);
            hitT = (startT + min(min(tMaxAxis.x, tMaxAxis.y), tMaxAxis.z)) / float(SUB_VOXEL_SIZE);
            return true;
        }

        if (tMaxAxis.x < tMaxAxis.y) {
            if (tMaxAxis.x < tMaxAxis.z) {
                voxel.x += step.x;
                tMaxAxis.x += tDelta.x;
                stepped_axis = 0u;
            } else {
                voxel.z += step.z;
                tMaxAxis.z += tDelta.z;
                stepped_axis = 2u;
            }
        } else {
            if (tMaxAxis.y < tMaxAxis.z) {
                voxel.y += step.y;
                tMaxAxis.y += tDelta.y;
                stepped_axis = 1u;
            } else {
                voxel.z += step.z;
                tMaxAxis.z += tDelta.z;
                stepped_axis = 2u;
            }
        }
    }

    return false;
}

// Ray-box intersection for sub-voxel cube (returns t and sets normal/localHit)
float raySubVoxelIntersect(vec3 origin, vec3 dir, vec3 boxMin, vec3 boxMax, out vec3 hitNormal, out vec3 localHit) {
    vec3 invDir = 1.0 / dir;

    vec3 t1 = (boxMin - origin) * invDir;
    vec3 t2 = (boxMax - origin) * invDir;

    vec3 tmin = min(t1, t2);
    vec3 tmax = max(t1, t2);

    float tNear = max(max(tmin.x, tmin.y), tmin.z);
    float tFar = min(min(tmax.x, tmax.y), tmax.z);

    if (tNear > tFar || tFar < 0.0) {
        return -1.0;
    }

    float t = tNear > 0.0 ? tNear : tFar;
    vec3 hitPoint = origin + dir * t;

    // Calculate normal based on which face was hit
    hitNormal = vec3(0.0);
    if (abs(hitPoint.x - boxMin.x) < 0.001) hitNormal = vec3(-1.0, 0.0, 0.0);
    else if (abs(hitPoint.x - boxMax.x) < 0.001) hitNormal = vec3(1.0, 0.0, 0.0);
    else if (abs(hitPoint.y - boxMin.y) < 0.001) hitNormal = vec3(0.0, -1.0, 0.0);
    else if (abs(hitPoint.y - boxMax.y) < 0.001) hitNormal = vec3(0.0, 1.0, 0.0);
    else if (abs(hitPoint.z - boxMin.z) < 0.001) hitNormal = vec3(0.0, 0.0, -1.0);
    else hitNormal = vec3(0.0, 0.0, 1.0);

    // Local hit in 0-1 space within sub-voxel
    localHit = (hitPoint - boxMin) / (boxMax - boxMin);

    return t;
}

// Render target block outline (wireframe only, drawn on top of hit block)
// This shows which block the player is looking at for breaking
bool renderTargetBlockOutline(vec3 origin, vec3 dir, inout vec3 color, float sceneHitDistance) {
    if (!hasTargetBlock()) {
        return false;
    }

    // target_block_x/y/z are already in texture coordinates (converted on CPU)
    // Ray marching uses texture coords (0 to textureSize), so use directly
    ivec3 targetPos = ivec3(pc.target_block_x, pc.target_block_y, pc.target_block_z);

    // Check if target is a Model block - skip outline for sub-voxel blocks
    uint blockType = readBlockTypeAtTexCoord(targetPos);
    if (blockType == BLOCK_MODEL) {
        return false;  // No outline for Model blocks (sub-voxel rendering handles them)
    }

    vec3 hitNormal;
    vec3 localHit;
    float t = rayBlockIntersect(origin, dir, targetPos, hitNormal, localHit);

    // Only render if we hit the target block at approximately the scene hit distance
    float tWorld = t * length(dir);
    if (t < 0.0 || abs(tWorld - sceneHitDistance) > 0.1) {
        return false;
    }

    // Calculate wireframe
    float wireframe = getWireframeFactor(localHit, hitNormal);

    // Only draw the outline, not the fill
    if (wireframe > 0.1) {
        vec3 outlineColor = vec3(0.0, 1.0, 1.0);  // Cyan outline
        float outlineAlpha = wireframe * 0.8;
        color = mix(color, outlineColor, outlineAlpha);
    }

    return true;
}

bool traversal(vec3 origin, vec3 dir, out vec3 color, inout uint steps, out float hitDistance) {
    hitDistance = FLT_MAX;

    vec3 inv_dir = 1. / dir;
    vec3 sgn_dir = sign(inv_dir);
    inv_dir = clamp(inv_dir, vec3(-FLT_MAX), vec3(FLT_MAX));

    vec3 t1 = -origin * inv_dir;
    vec3 t2 = (worldSize() - origin) * inv_dir;

    vec3 tmins = min(t1, t2);
    vec3 tmaxs = max(t1, t2);

    float tmin = 0;
    float tmax = FLT_MAX;
    for (int i = 0; i < 3; i++) {
        tmin = max(tmin, tmins[i]);
        tmax = min(tmax, tmaxs[i]);
    }

    if (tmin > tmax) {
        return false;
    }

    // Calculate max distance ray can travel in world
    float maxWorldDistance = tmax - tmin;

    // Step limit: DDA steps = sum of axis distances traveled
    // Calculate actual ratio based on ray direction for accuracy
    // Add 10% safety margin for numerical precision at screen corners
    vec3 absDir = abs(normalize(dir));
    float stepRatio = (absDir.x + absDir.y + absDir.z) * 1.1;
    uint dynamicMaxSteps = min(pc.max_ray_steps, uint(maxWorldDistance * stepRatio) + 16u);

    // Find which face the ray enters through (the axis with the LARGEST tmins)
    uint stepped_axis;
    if (tmins.x >= tmins.y && tmins.x >= tmins.z) {
        stepped_axis = 0;
    } else if (tmins.y >= tmins.z) {
        stepped_axis = 1;
    } else {
        stepped_axis = 2;
    }

    origin += dir * tmin;
    uvec3 coord = uvec3(clamp(floor(origin), vec3(0), worldSize() - 1.0));
    vec3 t = (coord + 0.5 * (1 + sgn_dir) - origin) * inv_dir;

    uvec3 ustep = uvec3(ivec3(sgn_dir));
    vec3 delta = inv_dir * sgn_dir;

    // Water tracking
    bool inWater = false;
    float waterEntryT = 0.0;
    float waterDepth = 0.0;
    vec3 waterSurfaceNormal = vec3(0.0);
    uint waterEntryAxis = 0;
    vec3 waterSurfaceHit = vec3(0.0);

    // Glass tracking
    bool passedGlass = false;
    float glassDepth = 0.0;
    float glassEntryT = 0.0;
    vec3 glassSurfaceNormal = vec3(0.0);
    vec3 glassSurfaceHit = vec3(0.0);
    uint glassEntryAxis = 0;
    ivec3 firstGlassCoord = ivec3(-1);  // Track first glass block for outline rendering
    vec3 firstGlassLocalHit = vec3(0.0);  // Local hit position within the glass block

    // Check for instant hit at entry point (coord is in texture space)
    uint blockType = readBlockTypeAtTexCoord(ivec3(coord));
    // Model blocks don't count as instant hit - we need to march through them
    // (player can be inside the empty part of a model block like a ladder)
    bool instantHit = (blockType != BLOCK_AIR && blockType != BLOCK_WATER && blockType != BLOCK_GLASS && blockType != BLOCK_MODEL);

    // If we start in water, mark it
    if (blockType == BLOCK_WATER) {
        inWater = true;
        waterEntryT = 0.0;
        // Entry from top (we're looking into water from above the world)
        waterSurfaceNormal = vec3(0.0, 1.0, 0.0);
        waterEntryAxis = 1;
        waterSurfaceHit = origin;
    }

    // If we start in glass, mark it
    if (blockType == BLOCK_GLASS) {
        passedGlass = true;
        glassEntryT = 0.0;
        glassSurfaceNormal = vec3(0.0, 1.0, 0.0);
        glassEntryAxis = 1;
        glassSurfaceHit = origin;
        firstGlassCoord = ivec3(coord);
        firstGlassLocalHit = origin - vec3(coord);
    }

    // Track previous t for water entry calculation
    float prevT = 0.0;

    // Sub-voxel model hit tracking
    bool subVoxelHit = false;
    vec3 subVoxelColor = vec3(0.5);
    vec3 subVoxelNormal = vec3(0.0, 1.0, 0.0);
    vec3 subVoxelHitPos = vec3(0.0);  // World position of sub-voxel hit

    if (!instantHit)
    while (steps < dynamicMaxSteps) {
        steps++;

        // Check bounds first
        if (any(greaterThanEqual(coord, worldSizeU()))) {
            // Exited world - if looking into water from above, return water color
            // If player is underwater, let sky render instead
            if (inWater && pc.player_in_water == 0) {
                waterDepth = (min(min(t.x, t.y), t.z) - waterEntryT) * length(dir);
                float depthFactor = 1.0 - exp(-waterDepth / WATER_CLARITY);
                color = mix(WATER_COLOR, WATER_DEEP_COLOR, depthFactor);
                hitDistance = waterEntryT * length(dir);
                return true;
            }
            return false;
        }

        // OPTIMIZATION: Check if current chunk is empty and skip to next chunk
        ivec3 chunkPos = ivec3(coord) / int(CHUNK_SIZE);
        if (isChunkEmpty(chunkPos)) {
            // Calculate exit point from this chunk
            vec3 currentPos = origin + dir * min(min(t.x, t.y), t.z);
            ivec3 chunkWorldPos = chunkPos * int(CHUNK_SIZE);
            vec3 chunkMin = vec3(chunkWorldPos);
            vec3 chunkMax = chunkMin + float(CHUNK_SIZE);

            // Find which face we exit through (determines entry face of next chunk)
            vec3 tExit = mix(
                (chunkMin - currentPos) * inv_dir,
                (chunkMax - currentPos) * inv_dir,
                step(vec3(0.0), dir)
            );

            // The axis with smallest positive tExit is our exit face
            float minExit = min(min(tExit.x, tExit.y), tExit.z);
            if (tExit.x == minExit) {
                stepped_axis = 0;
            } else if (tExit.y == minExit) {
                stepped_axis = 1;
            } else {
                stepped_axis = 2;
            }

            // Advance ray to chunk exit + epsilon
            vec3 newPos = currentPos + dir * (minExit + 0.001);

            // Update coord to new position
            coord = uvec3(clamp(floor(newPos), vec3(0), worldSize() - 1.0));

            // Recalculate t values for new position
            t = (vec3(coord) + 0.5 * (1.0 + sgn_dir) - origin) * inv_dir;

            // Don't continue - fall through to check the block we landed on
        }
        // OPTIMIZATION: Check if current brick is empty and skip to next brick
        else if (isBrickEmpty(ivec3(coord))) {
            vec3 currentPos = origin + dir * min(min(t.x, t.y), t.z);
            ivec3 brickWorldPos = getBrickWorldPos(ivec3(coord));
            vec3 brickMin = vec3(brickWorldPos);
            vec3 brickMax = brickMin + float(BRICK_SIZE);

            // Find which face we exit through (determines entry face of next brick)
            vec3 tExit = mix(
                (brickMin - currentPos) * inv_dir,
                (brickMax - currentPos) * inv_dir,
                step(vec3(0.0), dir)
            );

            // The axis with smallest positive tExit is our exit face
            float minExit = min(min(tExit.x, tExit.y), tExit.z);
            if (tExit.x == minExit) {
                stepped_axis = 0;
            } else if (tExit.y == minExit) {
                stepped_axis = 1;
            } else {
                stepped_axis = 2;
            }

            // Advance past brick boundary
            vec3 newPos = currentPos + dir * (minExit + 0.001);

            // Clamp to world bounds and update position
            newPos = clamp(newPos, vec3(0.0), worldSize() - 1.0);
            coord = uvec3(floor(newPos));

            // Recalculate t values for new position
            t = (vec3(coord) + 0.5 * (1.0 + sgn_dir) - origin) * inv_dir;

            // Don't continue - fall through to check the block we landed on
        }

        // Read block at current position
        blockType = readBlockTypeAtTexCoord(ivec3(coord));

        // Entering water
        if (blockType == BLOCK_WATER && !inWater) {
            inWater = true;
            waterEntryT = prevT;
            waterEntryAxis = stepped_axis;
            // Calculate surface normal (opposite of ray direction on stepped axis)
            waterSurfaceNormal = vec3(0.0);
            waterSurfaceNormal[stepped_axis] = -sgn_dir[stepped_axis];
            // Calculate water surface hit position
            waterSurfaceHit = origin + dir * prevT;
        }

        // Entering glass - track entry point for transparency blending
        if (blockType == BLOCK_GLASS && !passedGlass) {
            passedGlass = true;
            glassEntryT = prevT;
            glassEntryAxis = stepped_axis;
            // Calculate surface normal (opposite of ray direction on stepped axis)
            glassSurfaceNormal = vec3(0.0);
            glassSurfaceNormal[stepped_axis] = -sgn_dir[stepped_axis];
            // Calculate glass surface hit position
            glassSurfaceHit = origin + dir * prevT;
            // Track the first glass block coordinate for outline rendering
            firstGlassCoord = ivec3(coord);
            firstGlassLocalHit = glassSurfaceHit - vec3(coord);
        }

        // Accumulate glass depth while passing through glass blocks
        if (blockType == BLOCK_GLASS) {
            // Keep tracking glass - we'll calculate total depth later
            glassDepth += 1.0;  // Each glass block adds to depth
        }

        // Handle sub-voxel model blocks
        if (blockType == BLOCK_MODEL) {
            // Check if camera is physically inside this block
            vec3 cameraLocalPos = origin - vec3(coord);
            bool cameraInsideThisBlock =
                all(greaterThanEqual(cameraLocalPos, vec3(0.0))) &&
                all(lessThan(cameraLocalPos, vec3(1.0)));

            // Calculate entry point robustly
            vec3 localEntry;
            float distToBlock = 1e9;  // initialize to large so LOD check can safely fail when needed

            if (cameraInsideThisBlock) {
                localEntry = clamp(cameraLocalPos, vec3(0.001), vec3(0.999));
                distToBlock = 0.0;
            } else {
                vec3 entryNormal;
                vec3 entryLocal;
                float entryT = rayBlockIntersect(origin, dir, ivec3(coord), entryNormal, entryLocal);
                if (entryT < 0.0) {
                    // Should not happen, but treat as empty if it does
                    blockType = BLOCK_AIR;
                    distToBlock = 1e9;
                } else {
                    localEntry = clamp(entryLocal, vec3(0.001), vec3(0.999));
                    distToBlock = entryT * length(dir);
                }
            }

            // Read model metadata
            uvec2 metadata = readModelMetadata(ivec3(coord));
            uint model_id = metadata.r;
            uint rotation = metadata.g & 3u;

            // Try sub-voxel marching if within LOD distance
            if (model_id > 0u && distToBlock < SUB_VOXEL_LOD_DISTANCE) {
                vec3 subColor;
                vec3 subNormal;
                float subT;
                vec3 dirNorm = normalize(dir);
                if (marchSubVoxelModel(localEntry, dirNorm, model_id, rotation, subColor, subNormal, subT)) {
                    // Hit sub-voxel - store result and break
                    subVoxelHit = true;
                    subVoxelColor = subColor;
                    subVoxelNormal = subNormal;
                    // Calculate world position of sub-voxel hit for shadows/lighting
                    // localEntry is in 0-1 block space, subT is distance traveled in that space
                    subVoxelHitPos = vec3(coord) + localEntry + dirNorm * subT;
                    break;
                }
            }
            // Sub-voxel miss - continue marching through this block
            // (fall through to DDA step)
        }

        // Hit solid block (not air, not water, not glass, not model - we handle model above)
        if (blockType != BLOCK_AIR && blockType != BLOCK_WATER && blockType != BLOCK_GLASS && blockType != BLOCK_MODEL)
            break;

        // DDA step to next voxel (moved to end of loop)
        prevT = min(min(t.x, t.y), t.z);

        if (t.x < t.y) {
            if (t.x < t.z) {
                coord.x += ustep.x;
                t.x += delta.x;
                stepped_axis = 0;
            } else {
                coord.z += ustep.z;
                t.z += delta.z;
                stepped_axis = 2;
            }
        } else {
            if (t.y < t.z) {
                coord.y += ustep.y;
                t.y += delta.y;
                stepped_axis = 1;
            } else {
                coord.z += ustep.z;
                t.z += delta.z;
                stepped_axis = 2;
            }
        }
    }

    // If we exceeded max steps without hitting anything solid, return miss
    // Also treat BLOCK_MODEL with no sub-voxel hit as a miss (camera inside empty model space)
    bool modelMiss = (blockType == BLOCK_MODEL && !subVoxelHit);
    if (!instantHit && (blockType == BLOCK_AIR || blockType == BLOCK_WATER || blockType == BLOCK_GLASS || modelMiss)) {
        // Return water color if we passed through water
        if (inWater && pc.player_in_water == 0) {
            float currentT = min(min(t.x, t.y), t.z);
            waterDepth = (currentT - waterEntryT) * length(dir);
            float depthFactor = 1.0 - exp(-waterDepth / WATER_CLARITY);
            color = mix(WATER_COLOR, WATER_DEEP_COLOR, depthFactor);
            hitDistance = waterEntryT * length(dir);
            return true;
        }
        return false;
    }

    // Calculate water depth if we passed through water
    if (inWater) {
        float currentT = min(min(t.x, t.y), t.z) - min(delta.x, min(delta.y, delta.z));
        waterDepth = (currentT - waterEntryT) * length(dir);
    }

    vec3 mask = vec3(0);
    mask[stepped_axis] = 1;
    float t_inside = dot(t, mask) - dot(delta, mask);

    // Calculate hit distance for fog
    hitDistance = (tmin + t_inside) * length(dir);

    // Compute hit position and local coordinates within block
    vec3 hit = origin + dir * t_inside;
    vec3 local_hit = hit - coord;

    // Calculate normal for lighting, AO, and multi-face textures
    vec3 normal = -mask * sgn_dir;

    // Get block color based on block type (with texture sampling and multi-face support)
    vec3 blockColor;

    // Handle sub-voxel model rendering
    if (blockType == BLOCK_MODEL && subVoxelHit) {
        // Use stored sub-voxel hit results
        blockColor = subVoxelColor;
        normal = subVoxelNormal;
        // Apply target highlight for Model blocks (since they don't get wireframe outline)
        if (isTargetBlock(ivec3(coord))) {
            blockColor = applyTargetHighlight(blockColor);
        }
    } else if (blockType == BLOCK_MODEL) {
        // Model without stored hit (LOD fallback or empty model)
        blockColor = vec3(0.5, 0.5, 0.5);
        if (isTargetBlock(ivec3(coord))) {
            blockColor = applyTargetHighlight(blockColor);
        }
    } else {
        blockColor = getBlockColor(blockType, local_hit, normal, stepped_axis, hit);
    }

    // Calculate UV for AO (simplified - just need consistent mapping)
    vec2 uv;
    if (stepped_axis == 0) {
        uv = local_hit.yz;
    } else if (stepped_axis == 1) {
        uv = local_hit.xz;
    } else {
        uv = local_hit.xy;
    }

    // Distance-based LOD thresholds for expensive operations
    // Use push constant values if set, otherwise use defaults
    float aoDistance = pc.lod_ao_distance > 0.0 ? pc.lod_ao_distance : 32.0;
    float shadowDistance = pc.lod_shadow_distance > 0.0 ? pc.lod_shadow_distance : 64.0;
    float pointLightDistance = pc.lod_point_light_distance > 0.0 ? pc.lod_point_light_distance : 24.0;
    float skyExposureDistance = aoDistance; // Use same distance as AO

    bool nearEnoughForAO = hitDistance < aoDistance && pc.enable_ao != 0;
    bool nearEnoughForShadow = hitDistance < shadowDistance && pc.enable_shadows != 0;
    bool nearEnoughForPointLights = hitDistance < pointLightDistance && pc.enable_point_lights != 0;
    bool nearEnoughForSkyExposure = hitDistance < skyExposureDistance;

    // Calculate ambient occlusion only for nearby blocks (when enabled)
    // Skip AO for sub-voxel models - block-level AO doesn't apply to detailed geometry
    float ao = (nearEnoughForAO && !subVoxelHit) ? calculateAO(ivec3(coord), normal, uv) : 1.0;

    switch (pc.render_mode) {
        case COORD:
        color = vec3(coord) / (worldSize() - 1.0);
        break;
        case TEXTURED:
        {
        // Get current sun direction and daylight factor
        vec3 sunDir = getCurrentSunDir();
        float daylight = getDaylightFactor(pc.time_of_day);

        // Use sub-voxel hit position for lighting calculations if we hit a sub-voxel model
        vec3 lightingHit = subVoxelHit ? subVoxelHitPos : hit;

        // Calculate sky exposure (reduces ambient light underground) - skip for distant blocks
        float skyExposure = nearEnoughForSkyExposure ? getSkyExposure(lightingHit + normal * 0.01) : 1.0;

        // Calculate shadow only for nearby blocks
        float shadow = nearEnoughForShadow ? castShadowRay(lightingHit + normal * 0.01) : 1.0;

        // Apply directional lighting based on normal and sun direction
        float sunLight = max(0.0, dot(normal, sunDir));

        // Ambient varies with time of day (brighter during day, dimmer at night)
        // Sky exposure significantly reduces ambient light underground
        // pc.ambient_light is user-configurable base ambient level
        float baseAmbient = mix(pc.ambient_light, pc.ambient_light + 0.25, daylight);
        // Underground minimum scales with ambient setting (20% of base, minimum 0.02)
        float minAmbient = max(0.02, pc.ambient_light * 0.5);
        float ambient = mix(minAmbient, baseAmbient, skyExposure);

        // Direct light is also affected by sky exposure (no sun reaches underground)
        float direct = mix(0.2, 0.65, daylight) * sunLight * shadow * skyExposure;
        float lighting = ambient + direct;

        // Add point light contribution (torches, etc.) only for nearby blocks
        vec3 pointLightContrib = vec3(0.0);
        if (pc.light_count > 0 && nearEnoughForPointLights) {
            pointLightContrib = calculatePointLights(lightingHit, normal);
        }

        // Combine all lighting with ambient occlusion
        // Point lights add on top of base lighting (not affected by AO as much)
        color = blockColor * lighting * ao + blockColor * pointLightContrib * (0.7 + 0.3 * ao);
        }
        break;
        case NORMAL:
        // Visualize surface normals as colors (map -1..1 to 0..1)
        color = normal * 0.5 + 0.5;
        break;
        case UV:
        color = vec3(uv, 0);
        break;
        case DEPTH:
        float depth = (tmin + t_inside) * length(dir);
        // Use max dimension for depth scaling
        float maxDim = max(worldSize().x, max(worldSize().y, worldSize().z));
        color = vec3(1 / (1 + depth / maxDim)) + vec3(0.3, 0.0, 0.7) / 256;
        break;
        case BRICK_DEBUG:
        {
            // Simple test: just read the first word from each buffer
            // and show if brick_masks says empty or not
            uint testMask = brick_masks[0];
            uint testDist = brick_distances[0];

            // Simple visualization based on whether the hit block's brick is marked empty
            // Calculate brick index manually to avoid function call overhead
            ivec3 chunkPos = ivec3(coord) / int(CHUNK_SIZE);
            ivec3 localVoxel = ivec3(coord) - chunkPos * int(CHUNK_SIZE);
            ivec3 brickPos = localVoxel / int(BRICK_SIZE);

            uint brickIdx = uint(brickPos.x) + uint(brickPos.y) * BRICKS_PER_AXIS
                          + uint(brickPos.z) * BRICKS_PER_AXIS * BRICKS_PER_AXIS;
            uint chunkIdx = uint(chunkPos.x) + uint(chunkPos.z) * CHUNKS_X
                          + uint(chunkPos.y) * CHUNKS_X * CHUNKS_Z;

            uint maskOffset = chunkIdx * 2u;
            uint wordIdx = brickIdx / 32u;
            uint bitIdx = brickIdx % 32u;
            uint mask = brick_masks[maskOffset + wordIdx];
            bool brickHasSolid = (mask & (1u << bitIdx)) != 0u;

            bool blockIsAir = (blockType == BLOCK_AIR);

            // Color coding:
            // RED = brick marked empty but block is solid (BUG!)
            // GREEN = brick marked solid and block is solid (correct)
            // BLUE = brick marked solid but block is air (ok, other blocks might be solid)
            // DARK GRAY = brick marked empty and block is air (correct)
            if (!brickHasSolid && !blockIsAir) {
                color = vec3(1.0, 0.0, 0.0);  // RED = BUG
            } else if (brickHasSolid && !blockIsAir) {
                color = vec3(0.0, 0.8, 0.0);  // GREEN = correct solid
            } else if (brickHasSolid && blockIsAir) {
                color = vec3(0.3, 0.3, 0.8);  // BLUE = solid brick, air block
            } else {
                color = vec3(0.2, 0.2, 0.2);  // DARK GRAY = correct empty
            }

            // Use testMask and testDist to prevent optimization
            color += vec3(float(testMask & 1u), float(testDist & 1u), 0.0) * 0.001;
        }
        break;
    }

    // Apply crack overlay if this block is being broken
    if (isBreakingBlock(ivec3(coord))) {
        float crack = getCrackPattern(uv, pc.break_progress);
        // Darken the block where cracks appear
        color = mix(color, vec3(0.0), crack * 0.8);
    }

    // Apply chunk boundary wireframe overlay if enabled
    if (pc.show_chunk_boundaries != 0) {
        float boundaryFactor = chunkBoundaryFactor(hit, stepped_axis);
        if (boundaryFactor > 0.0) {
            // Yellow wireframe color
            vec3 wireColor = vec3(1.0, 1.0, 0.0);
            color = mix(color, wireColor, boundaryFactor * 0.8);
        }
    }

    // Apply water surface and depth effects if ray passed through water
    // Only apply surface reflection when player is OUTSIDE water looking in
    if (inWater && pc.player_in_water == 0) {
        // Get animated wave normal at water surface hit position
        vec3 animatedNormal = getWaterWaveNormal(waterSurfaceHit, pc.animation_time);

        // Blend animated normal with base surface normal
        // Stronger wave effect when looking at horizontal surfaces
        float normalBlend = abs(waterSurfaceNormal.y);
        vec3 finalNormal = normalize(mix(waterSurfaceNormal, animatedNormal, normalBlend));

        // Calculate fresnel reflection factor (more reflection at glancing angles)
        float viewDotNormal = abs(dot(normalize(dir), finalNormal));
        float fresnel = WATER_REFLECTIVITY + (1.0 - WATER_REFLECTIVITY) * pow(1.0 - viewDotNormal, WATER_FRESNEL_POWER);

        // Get sky reflection color using animated normal
        vec3 reflectDir = reflect(normalize(dir), finalNormal);
        vec3 reflectionColor = getSkyColor(reflectDir);

        // Apply surface reflection
        color = mix(color, reflectionColor, fresnel * 0.6);
    }

    // Apply depth-based water tinting (both when looking into water and when underwater)
    if (inWater && waterDepth > 0.0) {
        float depthFactor = 1.0 - exp(-waterDepth / WATER_CLARITY);
        // Blend between water surface color and deep water color
        vec3 waterTint = mix(WATER_COLOR, WATER_DEEP_COLOR, depthFactor * 0.5);
        // Apply tint to the object color - deeper = more tint
        color = mix(color, waterTint, depthFactor * 0.7);
    }

    // Apply glass surface effect and tinting
    if (passedGlass) {
        // Calculate local position for frame effect (based on the face we hit)
        vec3 localPos = firstGlassLocalHit;

        // Calculate 2D position on the hit face for frame drawing
        vec2 faceUV;
        if (abs(glassSurfaceNormal.x) > 0.5) {
            faceUV = localPos.yz;
        } else if (abs(glassSurfaceNormal.y) > 0.5) {
            faceUV = localPos.xz;
        } else {
            faceUV = localPos.xy;
        }

        // Create a visible frame/border effect like Minecraft glass
        float frameWidth = 0.08;  // Width of the frame
        float innerFrameWidth = 0.12;  // Inner highlight

        // Distance from edges (0 at edge, 0.5 at center)
        float distFromEdgeX = min(faceUV.x, 1.0 - faceUV.x);
        float distFromEdgeY = min(faceUV.y, 1.0 - faceUV.y);
        float distFromEdge = min(distFromEdgeX, distFromEdgeY);

        // Outer frame (darker/more visible)
        float outerFrame = 1.0 - smoothstep(0.0, frameWidth, distFromEdge);
        // Inner highlight
        float innerFrame = smoothstep(frameWidth, innerFrameWidth, distFromEdge) *
                          (1.0 - smoothstep(innerFrameWidth, innerFrameWidth + 0.04, distFromEdge));

        // Frame colors
        vec3 frameColor = vec3(0.7, 0.85, 0.9);  // Light blue-gray frame
        vec3 highlightColor = vec3(0.95, 0.98, 1.0);  // White highlight

        // Apply frame effect
        color = mix(color, frameColor, outerFrame * 0.6);
        color = mix(color, highlightColor, innerFrame * 0.3);

        // Add subtle fresnel for glassy look
        float viewDotNormal = abs(dot(normalize(dir), glassSurfaceNormal));
        float fresnel = 0.05 + 0.15 * pow(1.0 - viewDotNormal, 2.0);
        vec3 reflectDir = reflect(normalize(dir), glassSurfaceNormal);
        vec3 reflectionColor = getSkyColor(reflectDir);
        color = mix(color, reflectionColor, fresnel);

        // Apply depth-based tinting for multiple glass layers
        if (glassDepth > 1.0) {
            vec3 glassTint = vec3(0.92, 0.96, 1.0);  // Slight blue tint
            float depthFactor = min((glassDepth - 1.0) * 0.08, 0.25);
            color = mix(color, color * glassTint, depthFactor);
        }

        // Render target block outline on glass if this glass is the target
        if (hasTargetBlock()) {
            ivec3 targetPos = ivec3(pc.target_block_x, pc.target_block_y, pc.target_block_z);
            if (firstGlassCoord == targetPos) {
                // Calculate wireframe for cyan outline
                float wireframe = getWireframeFactor(firstGlassLocalHit, glassSurfaceNormal);
                if (wireframe > 0.1) {
                    vec3 outlineColor = vec3(0.0, 1.0, 1.0);  // Cyan
                    float outlineAlpha = wireframe * 0.9;
                    color = mix(color, outlineColor, outlineAlpha);
                }
            }
        }
    }

    return true;
}

void main() {
    ivec2 pixelCoord = ivec2(gl_GlobalInvocationID.xy);

    // Pass mode 1: Distance-only pass (writes to distance buffer)
    if (pc.pass_mode == 1) {
        ivec2 distSize = imageSize(distanceImage);
        if (any(greaterThanEqual(pixelCoord, distSize)))
            return;

        vec3 o = pc.pixelToRay[3].xyz;
        // Scale pixel coord to match 1/4 resolution
        vec3 d = mat3(pc.pixelToRay) * vec3(pixelCoord * 4 + 2, 1);  // Center of 4x4 block

        vec3 color;
        uint steps = 0;
        float hitDistance = 9999.0;

        traversal(o, d, color, steps, hitDistance);

        imageStore(distanceImage, pixelCoord, vec4(hitDistance, 0, 0, 0));
        return;
    }

    // Normal rendering (pass_mode 0 or 2)
    ivec2 imageSize = imageSize(targetImage);
    if (any(greaterThanEqual(pixelCoord, imageSize)))
        return;

    vec3 o = pc.pixelToRay[3].xyz;
    vec3 d = mat3(pc.pixelToRay) * vec3(pixelCoord, 1);

    // Pass mode 2: Use distance hints to start ray closer to surface
    if (pc.pass_mode == 2) {
        // Sample distance hint from low-res buffer
        ivec2 distCoord = pixelCoord / 4;
        float hintDist = imageLoad(distanceImage, distCoord).r;

        // Only use hint if it's valid (not the initial 9999 for sky misses)
        if (hintDist < 9000.0) {
            // Start ray at hint distance minus safety margin (8 blocks)
            // The direction d is unnormalized, so we need to normalize for distance calculation
            vec3 normalizedDir = normalize(d);
            float startT = max(0.0, hintDist - 8.0);
            o = o + normalizedDir * startT;
        }
    }

    vec3 color;
    uint steps = 0;
    float hitDistance;

    bool hit = traversal(o, d, color, steps, hitDistance);

    bool underwater = pc.player_in_water != 0;

    if (pc.render_mode == STEPS) {
        // Use max dimension for step count scaling
        uint maxDim = max(pc.texture_size_x, max(pc.texture_size_y, pc.texture_size_z));
        color = stepsToInferno(steps, 0, (maxDim - 1) * 3);
    } else if (hit) {
        // Render target block outline (wireframe around block player is looking at)
        renderTargetBlockOutline(o, d, color, hitDistance);
        // Apply fog to hit blocks
        color = applyFog(color, hitDistance, d);
    } else {
        // Ray missed - show sky (with sun and clouds)
        color = getSkyColor(d);
        // Optionally apply fog to sky
        if (pc.fog_affects_sky != 0u) {
            // Use the texture size as approximate max view distance
            float skyDistance = length(vec3(pc.texture_size_x, pc.texture_size_y, pc.texture_size_z)) * 0.5;
            color = applyFog(color, skyDistance, d);
        }
    }

    // Render particles on top of scene (with fog)
    if (pc.particle_count > 0 && pc.render_mode != STEPS) {
        float particleDist = hitDistance;
        renderParticles(o, d, color, particleDist);
        // Apply fog to particles if they're closer than the hit
        if (particleDist < hitDistance) {
            // Particles already have their color, just need fog
            vec3 fogColor = getFogColor(pc.time_of_day);
            float fogFactor = smoothstep(FOG_START, FOG_END, particleDist);
            color = mix(color, fogColor, fogFactor * 0.3);  // Lighter fog on particles
        }
    }

    // Render falling blocks (sand, gravel in motion)
    if (pc.falling_block_count > 0 && pc.render_mode != STEPS) {
        float fallingDist = hitDistance;
        renderFallingBlocks(o, d, color, fallingDist);
        // Apply fog to falling blocks if they're closer than the hit
        if (fallingDist < hitDistance) {
            vec3 fogColor = getFogColor(pc.time_of_day);
            float fogFactor = smoothstep(FOG_START, FOG_END, fallingDist);
            color = mix(color, fogColor, fogFactor * 0.5);
        }
    }

    // Render block placement preview (ghost block with wireframe)
    if (pc.render_mode != STEPS) {
        renderPreviewBlock(o, d, color, hitDistance);
    }

    // Apply underwater visual effect when player is submerged
    if (underwater) {
        // Subtle underwater wave distortion using animated noise
        vec2 screenUV = vec2(pixelCoord) / vec2(imageSize);
        float waveDistort = noise2D(screenUV * 8.0 + vec2(pc.animation_time * 0.5, pc.animation_time * 0.3)) * 0.02;
        waveDistort += noise2D(screenUV * 15.0 + vec2(-pc.animation_time * 0.4, pc.animation_time * 0.6)) * 0.01;

        // Apply subtle color variation based on wave distortion
        float colorShift = waveDistort * 3.0;

        // Blue-green underwater tint with subtle wave-based variation
        vec3 underwaterTint = vec3(0.15, 0.35 + colorShift, 0.55 + colorShift * 0.5);
        color = mix(color, underwaterTint, 0.3);
    }

    // Prevent shader optimizer from removing brick metadata buffers (set 7)
    // by unconditionally reading from them with negligible visual impact
    color += vec3(float(brick_masks[0] & 1u), float(brick_distances[0] & 1u), 0.0) * 0.00001;

    imageStore(targetImage, pixelCoord, vec4(color, 1));
}
